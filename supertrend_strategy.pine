//@version=5
strategy("Bitcoin SuperTrend 1H (Aggressive)", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_type=strategy.commission.percent, commission_value=0.1)

// --- Inputs ---
atrPeriod = input.int(10, "ATR Length", minval=1)
factor = input.float(5.0, "Factor", minval=0.1, step=0.1)

// --- SuperTrend Calculation ---
[superTrend, direction] = ta.supertrend(factor, atrPeriod)

// --- Logic ---
// direction < 0 means Uptrend (SuperTrend below price)
// direction > 0 means Downtrend (SuperTrend above price)

isUptrend = direction < 0
isDowntrend = direction > 0

// --- Execution (Always In) ---
if isUptrend
    strategy.entry("Long", strategy.long, comment="Bull 🚀")

if isDowntrend
    strategy.entry("Short", strategy.short, comment="Bear 🐻")

// --- Plotting ---
bodyMiddle = plot((open + close) / 2, display=display.none)
upTrend = plot(isUptrend ? superTrend : na, "Up Trend", color = color.green, style=plot.style_linebr)
downTrend = plot(isDowntrend ? superTrend : na, "Down Trend", color = color.red, style=plot.style_linebr)

fill(bodyMiddle, upTrend, color.new(color.green, 90), fillgaps=false)
fill(bodyMiddle, downTrend, color.new(color.red, 90), fillgaps=false)

// Plot Signals
plotshape(isUptrend and not isUptrend[1], title="Buy", style=shape.labelup, location=location.belowbar, color=color.green, text="BUY", textcolor=color.white, size=size.tiny)
plotshape(isDowntrend and not isDowntrend[1], title="Sell", style=shape.labeldown, location=location.abovebar, color=color.red, text="SELL", textcolor=color.white, size=size.tiny)
