# ============================================
# CONFIGURACIÓN DEL BOT DE TRADING
# ============================================

# CREDENCIALES DEL EXCHANGE
# Para Hyperliquid:
WALLET_ADDRESS=your_wallet_address_here
PRIVATE_KEY=your_private_key_here

# Para otros exchanges (Binance, Bybit, etc.):
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_SECRET=your_api_secret_here

# IMPORTANTE: 
# - NO compartas este archivo con nadie
# - NO lo subas a GitHub u otros repositorios públicos
# - En el VPS, asegúrate de que tenga permisos 600 (chmod 600 .env)
